PORT=5000
MONGO_URI=your_mongodb_connection_string_here

# Secret used to sign JWTs — use a long random string in production.
JWT_SECRET=replace_with_a_long_random_secret
# How long an access token stays valid (zeit/ms format: 7d, 12h, 30m...).
JWT_EXPIRES_IN=7d

# Firebase Admin SDK (from service account JSON)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional: Frontend URL(s) for CORS (comma-separated)
# CLIENT_URL=https://your-app.vercel.app

# Optional: For migration script — assign orphaned habits to this user
# TARGET_USER_EMAIL=user@example.com
